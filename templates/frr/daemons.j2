# AtlasLab - generated by scripts/generate-configs.py - DO NOT EDIT BY HAND
# lab={{ lab }} node={{ node }} role={{ role }}
#
# Enables only the daemons this node's role requires:
#   zebra    - always required (RIB / interface manager)
#   staticd  - always required (zebra dependency for static/Null0 routes)
#   ospfd    - {{ 'yes' if ospf_enabled else 'no' }} ({{ 'campus IGP speaker' if ospf_enabled else 'not part of the OSPF domain' }})
#   bgpd     - {{ 'yes' if bgp_enabled else 'no' }} ({{ 'BGP speaker' if bgp_enabled else 'no BGP session on this node' }})
zebra=yes
bgpd={{ 'yes' if bgp_enabled else 'no' }}
ospfd={{ 'yes' if ospf_enabled else 'no' }}
ospf6d=no
ripd=no
ripngd=no
isisd=no
pimd=no
pim6d=no
ldpd=no
nhrpd=no
eigrpd=no
babeld=no
sharpd=no
pbrd=no
bfdd=no
fabricd=no
vrrpd=no
pathd=no
staticd=yes

vtysh_enable=yes
zebra_options="  -A 127.0.0.1 -s 90000000"
bgpd_options="   -A 127.0.0.1"
ospfd_options="  -A 127.0.0.1"
staticd_options="-A 127.0.0.1"

#!/bin/sh
# AtlasLab - atlaslab/firewall "show" CLI (fwsh)
#
# The atlas SSH user's login shell on every firewall node - same
# pattern as vtysh being the login shell on atlaslab/frr nodes, scoped
# to this image's role instead. Deliberately narrow: read-only "show"
# commands only, backed by a tightly-scoped doas rule for the one or
# two operations (viewing live iptables counters) that genuinely need
# root - there is no general shell access and no way to modify firewall
# state from this CLI. See /etc/doas.conf for exactly what's elevated.
#
# Handles both SSH exec mode (`ssh atlas@host "show interfaces"`, which
# sshd runs as `fwsh -c "show interfaces"`) and an interactive REPL
# (`ssh atlas@host` with no command).

HOSTNAME="$(cat /etc/hostname 2>/dev/null || hostname)"

run_show() {
  cmd="$*"
  case "$cmd" in
    "show version")
      echo "AtlasLab firewall (${HOSTNAME}) on $(uname -sr)"
      grep PRETTY_NAME /etc/os-release
      ;;
    "show hostname")
      echo "$HOSTNAME"
      ;;
    "show interfaces"|"show interface"|"show ip interface")
      ip -br addr show
      ;;
    "show ip route"|"show route")
      ip route
      ;;
    "show firewall rules"|"show rules"|"show iptables"|"show ip firewall")
      doas /usr/sbin/iptables -L FORWARD -n -v --line-numbers
      ;;
    "show running-config"|"show config")
      echo "! /etc/atlaslab-firewall/setup.sh (generated by scripts/generate-multicity.py)"
      cat /etc/atlaslab-firewall/setup.sh
      ;;
    "show lldp neighbors"|"show lldp neighbor"|"show lldp")
      lldpcli show neighbors
      ;;
    "show log")
      tail -n 40 /var/log/atlaslab/firewall.log
      ;;
    "show help"|"help"|"?")
      cat <<'EOF'
Available commands:
  show version           - image/OS identity (includes hostname)
  show hostname           - this node's hostname
  show interfaces        - interface addressing (ip -br addr)
  show route              - routing table (ip route)
  show firewall rules    - iptables FORWARD chain, with packet/byte counters
  show lldp neighbors    - LLDP-discovered neighbors on topology links
  show running-config    - the generated setup.sh this node booted with
  show log                - startup / config-apply log
  exit | quit             - end session
EOF
      ;;
    "exit"|"quit")
      exit 0
      ;;
    "")
      ;;
    *)
      echo "% Unknown command: ${cmd}"
      echo "Type 'show help' for available commands."
      return 1
      ;;
  esac
}

if [ "$1" = "-c" ]; then
  shift
  run_show "$*"
  exit $?
fi

echo "AtlasLab firewall CLI - ${HOSTNAME}"
echo "Type 'show help' for available commands, 'exit' to quit."
while true; do
  printf '%s> ' "$HOSTNAME"
  IFS= read -r line || { echo; break; }
  [ -z "$line" ] && continue
  run_show "$line"
done

# ============================================================
# AtlasLab .gitignore
# Only generated/runtime artifacts are ignored. Source topology
# files (lab.clab.yml), templates, and rendered FRR configs that
# are checked in under configs/ are intentionally tracked.
# ============================================================

# Containerlab runtime state
clab-*/
**/clab-*/
.clab/
.state.clab.yaml
*.clab.yml.bak
topology-data.json
ansible-inventory.yml
ansible-inventory.yaml
inventory/**/hosts.ini
inventory/**/hosts.yaml
.topology-data.json

# Containerlab generated per-node runtime dirs
**/*.startup.log
**/*.pid

# Logs & captures produced by scripts/*.sh at runtime
logs/*.log
logs/*.txt
captures/*.pcap
captures/*.pcapng

# Diagnostics bundles produced by collect-diagnostics.sh
logs/diagnostics-*/
logs/diagnostics-*.tar.gz

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Python (config generator)
__pycache__/
*.pyc
.venv/

# SSH keys accidentally generated by containerlab
**/.ssh/
*.ppk
